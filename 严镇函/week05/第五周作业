import math

import torch
import torch.nn as nn
import torch.nn.functional as F



#训练基于transformer的单向语言模型，并完成文本生成
#单语言就mask是倒三角形状
#写一个关于古诗的给上句话提供给下句

#先准备一个古诗的训练集
#对训练集进行处理
MAXLEN = 5
import glob

def load_txt(file_path="古诗.txt"):
    poem_list = []
    with open(file_path, "r",encoding="utf-8") as f:
        for line in f.readlines():
            #去除空格方便编号
            line = line.strip()
            if line:
                poem_list.append(line)
    return poem_list


#构建词表
def build_vocab(date):
    vocab = {"<PAD>":0, "<UNK>":1}
    for sent in date:
        for word in sent:
            if word not in vocab:
                vocab[word] = len(vocab)
    return vocab

#编码对应句子
def encode(sent,vocab,max_len=5):
    ids = [vocab.get(ch,1) for ch in sent]
    ids = ids[:max_len]
    ids += [0]*(max_len-len(ids))
    return ids

#多头注意力
class MultiHeadAttention(nn.Module):
    def __init__(self,embed_dim,num_heads):
        super().__init__()
        self.embed_dim = embed_dim
        self.num_heads = num_heads
        #计算每个头的维度
        self.head_dim = embed_dim // num_heads
        #qkc权重
        self.wq = nn.Linear(embed_dim,embed_dim)
        self.wk = nn.Linear(embed_dim,embed_dim)
        self.wv = nn.Linear(embed_dim,embed_dim)
        #输出最后拼接
        self.out = nn.Linear(embed_dim,embed_dim)


    def forward(self,x,mask = None):
        #记录输入的维度
        B, N, C = x.shape
        #计算权重
        q = self.wq(x)
        k = self.wk(x)
        v = self.wv(x)
        #划分多个头
        q = q.view(B,N,self.num_heads,self.head_dim).transpose(1,2)
        k = k.view(B,N,self.num_heads,self.head_dim).transpose(1,2)
        v = v.view(B,N,self.num_heads,self.head_dim).transpose(1,2)
        #开始计算
        qk = torch.matmul(q, k.transpose(-1,-2)) / math.sqrt(self.head_dim)
        if mask is not None:
            qk = qk.masked_fill(mask==0, -1e9)
        qk = F.softmax(qk, dim=-1)
        out = qk@v
        #拼接多个头
        out = out.transpose(1,2).contiguous().view(B,N,C)
        out = self.out(out)
        return out
#前馈网络
class FeedForward(nn.Module):
    def __init__(self,embed_dim):
        super().__init__()
        self.embed_dim = embed_dim
        #扩大
        self.fc1 = nn.Linear(embed_dim,embed_dim*4)
        #还原
        self.fc2 = nn.Linear(embed_dim*4,embed_dim)

    def forward(self,x):
        x = self.fc1(x)
        x = F.gelu(x)
        x = self.fc2(x)
        return x

#这个就是一次处理一个序列的transformer block
class TransformerBlock(nn.Module):
    def __init__(self,embed_dim,num_heads):
        super().__init__()
        #开始组装
        self.attention = MultiHeadAttention(embed_dim,num_heads)
        self.ff = FeedForward(embed_dim)
        #层归一化
        self.layer_norm = nn.LayerNorm(embed_dim)
        self.layer_norm2 = nn.LayerNorm(embed_dim)
    def forward(self,x,mask = None):
        #这个我记得是因为要每次都给最开始的x加上归一化之后的结果，否则会丢失信息
        attn_out = self.attention(self.layer_norm(x), mask)
        x = x + attn_out
        ff_out = self.ff(self.layer_norm2(x))
        x = x + ff_out
        return x

#多次调用transformer block
class Transformer(nn.Module):
    def __init__(self,voca_size,embed_dim,num_heads):
        super().__init__()
        self.num_heads = num_heads
        #词嵌入
        self.embedding = nn.Embedding(voca_size,embed_dim)
        #位置嵌入
        self.pos_emb = nn.Embedding(MAXLEN, embed_dim)

        #调用块
        self.layers = nn.ModuleList([
            TransformerBlock(embed_dim,num_heads)
            for _ in range(6)
        ])

        self.norm = nn.LayerNorm(embed_dim)
        self.fc = nn.Linear(embed_dim,voca_size)

    def forward(self,x):
        B,N = x.shape
        x = self.embedding(x)

        pos = torch.arange(N, device=x.device).unsqueeze(0)  # 生成位置 0,1,2...
        x = x + self.pos_emb(pos)

        #下三角
        # mask = torch.tril(torch.ones((N,N))).unsqueeze(0).expand(B,N,N).to(x.device)
        mask = torch.tril(torch.ones(N, N, device=x.device)).view(1, 1, N, N)


        #调用块
        for layer in self.layers:
            x = layer(x,mask)

        x = self.norm(x)
        out = self.fc(x)
        return out

#开始训练
def train():
    embed_dim = 256  # 增大嵌入维度
    num_heads = 8    # 增加头数
    lr = 1e-4        # 降低学习率，更稳定
    epoch_num = 500  # 增加训练轮数

    #造数据+构建词表
    print("生成数据集...")
    poems = load_txt()
    vocab = build_vocab(poems)
    vocab_size = len(vocab)

    all_data = [encode(p, vocab, MAXLEN) for p in poems]
    all_data = torch.tensor(all_data, dtype=torch.long)
    
    #创建模型+优化器 + 损失函数
    model = Transformer(vocab_size, embed_dim, num_heads)
    opt = torch.optim.Adam(model.parameters(), lr=lr)
    # 忽略PAD位置的损失（PAD的index是0）
    loss_fn = nn.CrossEntropyLoss(ignore_index=0)
    
    print("模型参数总数：", sum(p.numel() for p in model.parameters()))
    print("开始训练...")
    for e in range(epoch_num):
        model.train()

        # 语言模型训练：用前n-1个字符预测第n个字符
        inp_seq = all_data[:, :-1]  # 输入：前MAXLEN-1个字符
        lab_seq = all_data[:, 1:]   # 标签：后MAXLEN-1个字符
        pred = model(inp_seq)
        loss = loss_fn(pred.permute(0, 2, 1), lab_seq)

        opt.zero_grad()
        loss.backward()
        opt.step()
        if e % 5 == 0:
            print(f"轮次 {e:2d}/{epoch_num}  损失值={loss.item():.4f}")
    print("训练完成")
    print("模型保存中...")
    torch.save(model.state_dict(), "古诗模型_model.pth")
    print("模型保存完成")
    return model, vocab

def load_model(vocab):
    vocab_size = len(vocab)
    net = Transformer(vocab_size, 128, 4)
    net.load_state_dict(torch.load("古诗模型_model.pth"))
    net.eval()
    return net
#
def generate_poem(model, vocab, input_txt, max_len=MAXLEN):
    model.eval()
    with torch.no_grad():
        # 编码输入的开头
        input_ids = encode(input_txt, vocab, max_len=MAXLEN)
        x = torch.tensor([input_ids], dtype=torch.long)

        # 自回归生成：从输入长度开始续写（最多写到MAXLEN-1）
        for i in range(len(input_txt), MAXLEN):
            # 输入前i个字符（x[:, :i]），预测第i+1个字符
            if i == 0:
                continue  # 至少需要1个字符作为输入
            
            logits = model(x[:, :i])  # 输入前i个字符
            # 取最后一个位置的预测
            current_logits = logits[:, -1, :]
            # 将PAD和UNK的概率设为负无穷，禁止选择
            current_logits[0, 0] = -float('inf')  # PAD
            current_logits[0, 1] = -float('inf')  # UNK
            # 贪心搜索：选择概率最大的字符
            next_token = torch.argmax(current_logits, dim=-1).item()
            
            x[0, i] = next_token
        
        # 提取结果
        res = ""
        for idx in x[0]:
            num = idx.item()
            if num == 0 or num == 1:  # 跳过PAD和UNK
                break
            for word, idx_v in vocab.items():
                if idx_v == num:
                    res += word
                    break
    
    return res


# ==================== 最终主函数 ====================
if __name__ == "__main__":
    # 1. 训练
    model, vocab = train()
    #
    # 2. 自动进入交互式生成
    print("\n✅ 训练完成！开始续写诗句啦~")
    while True:
        text = input("输入诗句开头（q退出）：")
        if text == "q":
            break
        res = generate_poem(model, vocab, text)
        print(f"完整诗句：{res}\n")
